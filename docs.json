{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Drift CLI",
  "theme": "aspen",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/drift-tech/drift-releases"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/drift-tech/drift-releases",
      "website": "https://godrift.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/natural-language",
              "features/workspace-management",
              "features/launch-files",
              "features/process-management",
              "features/debugging"
            ]
          },
          {
            "group": "Usage Guide",
            "pages": [
              "guide/basic-commands",
              "guide/special-commands",
              "guide/building-robots",
              "guide/troubleshooting"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/system-requirements",
              "reference/ros2-integration",
              "reference/gazebo-integration",
              "reference/updates"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Help & Support",
            "pages": [
              "support/faq",
              "support/community",
              "support/changelog"
            ]
          }
        ]
      }
    ]
  }
}
